# Database Connection (sqlite default, change to postgresql for production)
DATABASE_URL=sqlite:///./quantra.db

# JWT Secret Key (generate a strong secure random key in production)
SECRET_KEY=quantra-super-secret-key-1234567890abcdef

# Access token duration (in minutes, default is 24 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Next.js API endpoint target (points to FastAPI backend)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Allowed CORS Origins (comma-separated, default is http://localhost:3000,http://127.0.0.1:3000)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
